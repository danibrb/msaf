# ============================================================
#  .gitignore — Python Project (Windows + VSCode)
#  Best practices: https://git-scm.com/docs/gitignore
# ============================================================


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

# Bytecode / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/

# Virtual environments (tutti i nomi comuni)
.venv/
venv/
env/
ENV/
.env/
virtualenv/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# pyenv / pipenv / poetry
.python-version
Pipfile.lock
poetry.lock        # ← rimuovi questa riga se vuoi versionare il lock file (consigliato)

# Sphinx documentation
docs/_build/
docs/_autosummary/

# PyInstaller
*.manifest
*.spec

# Translations
*.mo
*.pot

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Scrapy
.scrapy


# ------------------------------------------------------------
# Environment & Secrets — CRITICO: non committare mai segreti
# ------------------------------------------------------------

.env
.env.*
!.env.example          # ← eccezione: il template è versionato
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml
*_secret*
*_secrets*
config/local.py
config/local.yaml


# ------------------------------------------------------------
# Database & Data files
# ------------------------------------------------------------

*.db
*.sqlite
*.sqlite3
*.sql
*.csv         # rimuovi se vuoi versionare i dataset
*.parquet
*.h5
*.hdf5
data/raw/
data/processed/
data/external/


# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------

*.log
logs/
*.log.*
log/


# ------------------------------------------------------------
# VSCode
# ------------------------------------------------------------

.vscode/*
!.vscode/settings.json        # ← mantieni le impostazioni condivise del progetto
!.vscode/extensions.json      # ← consigliato per il team
!.vscode/launch.json          # ← configurazioni di debug condivise
*.code-workspace


# ------------------------------------------------------------
# Windows
# ------------------------------------------------------------

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp


# ------------------------------------------------------------
# macOS (se lavori in team cross-platform)
# ------------------------------------------------------------

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------

*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.idea/               # JetBrains IDEs
